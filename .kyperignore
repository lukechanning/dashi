# .kyperignore — patterns to exclude from the Kyper upload archive.
# Syntax: one pattern per line, # for comments, trailing / for directories.
# This file was generated by `kyper init`. Edit freely.

# Environment & secrets (never upload these)
.env
.env.*
.env.local
.env.*.local
*.pem
*.key
*.p12

# Rails
log/
storage/
.bundle/
