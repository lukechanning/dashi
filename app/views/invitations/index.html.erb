<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-app-text">Invitations</h1>
  <%= link_to "Invite someone", new_invitation_path, class: primary_button_class("rounded-lg px-4 py-2 text-sm") %>
</div>

<% if @invitations.any? %>
  <div class="bg-app-surface rounded-lg border border-app-border divide-y divide-app-border">
    <% @invitations.each do |invitation| %>
      <div class="flex items-center justify-between p-4">
        <div>
          <span class="text-app-text"><%= invitation.email %></span>
          <span class="text-xs text-app-faint ml-2">invited <%= time_ago_in_words(invitation.created_at) %> ago</span>
        </div>
        <span class="text-xs px-2 py-1 rounded-full <%= invitation.accepted? ? 'bg-app-success-soft text-app-success' : 'bg-app-warning-soft text-app-warning' %>">
          <%= invitation.accepted? ? "Accepted" : "Pending" %>
        </span>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="text-center py-12 text-app-muted">
    <p>No invitations sent yet.</p>
  </div>
<% end %>
