<h1 class="text-2xl font-bold text-app-text mb-6">Invite someone</h1>

<%= form_with model: @invitation, url: invitations_path, class: "space-y-4 max-w-sm" do |f| %>
  <%= render "shared/error_messages", model: @invitation %>

  <div>
    <%= f.label :email, "Email address", class: form_label_class %>
    <%= f.email_field :email, required: true, autofocus: true, placeholder: "friend@example.com",
        value: @invitation.email,
        class: form_control_class %>
  </div>

  <div class="flex items-center gap-3">
    <%= f.submit "Send invitation", class: primary_button_class("text-sm") %>
    <%= link_to "Cancel", invitations_path, class: muted_link_class("text-sm") %>
  </div>
<% end %>
