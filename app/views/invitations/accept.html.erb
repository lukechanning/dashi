<div class="min-h-screen flex items-center justify-center">
  <div class="w-full max-w-sm">
    <h1 class="text-2xl font-bold text-app-text text-center mb-2">Welcome to Dashi</h1>
    <p class="text-center text-app-muted mb-8">Set up your account to get started.</p>

    <%= form_with url: register_invitation_path(token: @invitation.token), method: :post, class: "space-y-4" do |f| %>
      <div>
        <label class="<%= form_label_class("mb-1") %>">Email</label>
        <p class="text-app-text px-3 py-2 bg-app-surface-muted rounded-lg border border-app-border"><%= @invitation.email %></p>
      </div>

      <div>
        <%= f.label "user[name]", "Your name", class: form_label_class("mb-1") %>
        <%= f.text_field "user[name]", required: true, autofocus: true, placeholder: "Your name",
            class: form_control_class("rounded-lg focus:ring-violet-500") %>
      </div>

      <%= f.submit "Create account", class: primary_button_class("w-full rounded-lg px-4 py-2") %>
    <% end %>
  </div>
</div>
