<%= form_with model: todo, class: "space-y-5" do |f| %>
  <%= render "shared/error_messages", model: todo %>

  <div>
    <%= f.label :title, class: form_label_class %>
    <%= f.text_field :title, required: true, autofocus: true,
        class: form_control_class("py-2.5 shadow-sm") %>
  </div>

  <div>
    <%= f.label :due_date, "Scheduled for (optional)", class: form_label_class %>
    <%= f.date_field :due_date,
        class: form_control_class("w-auto py-2.5 shadow-sm") %>
  </div>

  <div>
    <%= f.label :project_id, "Project (optional)", class: form_label_class %>
    <%= f.collection_select :project_id, current_user.projects.active.ordered, :id, :title,
        { include_blank: "None (standalone todo)" },
        class: form_control_class("w-auto py-2.5 shadow-sm") %>
  </div>

  <div class="flex items-center gap-3 pt-1">
    <%= f.submit class: primary_button_class("text-sm shadow-sm") %>
    <%= link_to "Cancel", :back, class: muted_link_class("text-sm transition-colors") %>
  </div>
<% end %>
