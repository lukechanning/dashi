<div class="mb-6">
  <% if @project.goal %>
    <p class="text-sm text-app-muted mb-1">
      <%= link_to [@project.goal.emoji, @project.goal.title].compact.join(" "), goal_path(@project.goal), class: "hover:text-app-text" %>
    </p>
  <% end %>

  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-bold text-app-text"><%= [@project.emoji, @project.title].compact.join(" ") %></h1>
    <div class="flex items-center gap-2">
      <%= link_to "Edit", edit_project_path(@project), class: muted_link_class("text-sm") %>
      <%= button_to "Delete", project_path(@project), method: :delete,
          data: { turbo_confirm: "Delete this project and all its todos?" },
          class: "text-sm text-app-danger hover:opacity-80 cursor-pointer" %>
    </div>
  </div>

  <% if @project.description.present? %>
    <p class="text-app-muted mt-2"><%= @project.description %></p>
  <% end %>

  <div class="flex items-center gap-2 mt-3">
    <% if @project.active? %>
      <%= button_to "Mark complete", project_path(@project), method: :patch,
          params: { project: { status: "completed" } },
          class: "px-3 py-1.5 text-sm font-medium bg-app-success-soft text-app-success rounded-xl hover:opacity-85 transition-colors cursor-pointer" %>
      <%= button_to "Archive", project_path(@project), method: :patch,
          params: { project: { status: "archived" } },
          class: "px-3 py-1.5 text-sm font-medium bg-app-danger-soft text-app-danger rounded-xl hover:opacity-85 transition-colors cursor-pointer" %>
    <% else %>
      <span class="text-xs px-2 py-1 rounded-full bg-app-surface-muted text-app-muted font-medium">
        <%= @project.status.capitalize %>
      </span>
      <%= button_to "Reactivate", project_path(@project), method: :patch,
          params: { project: { status: "active" } },
          class: primary_button_class("px-3 py-1.5 text-sm") %>
    <% end %>
  </div>

  <div class="mt-4">
    <%= render "shared/contribution_graph", record: @project %>
  </div>
</div>

<%= render "shared/members_section", memberable: @project %>

<% if @habits.any? %>
  <div class="flex items-center justify-between mb-4">
    <h2 class="text-lg font-semibold text-app-text">Habits</h2>
    <%= link_to "Add habit", new_habit_path(project_id: @project.id), class: primary_link_class("text-sm") %>
  </div>
  <div class="space-y-2 mb-8">
    <% @habits.each do |habit| %>
      <%= render "habits/habit_card", habit: habit, show_project: false %>
    <% end %>
  </div>
<% end %>

<div class="flex items-center justify-between mb-4">
  <h2 class="text-lg font-semibold text-app-text">Todos</h2>
  <%= link_to "Add todo", new_todo_path(project_id: @project.id), class: primary_link_class("text-sm") %>
</div>

<% if @todos.any? %>
  <div class="space-y-2">
    <% @todos.each do |todo| %>
      <div class="<%= card_class("flex items-center gap-3 rounded-xl p-3") %>">
        <%= button_to toggle_todo_path(todo), method: :patch, class: "flex-shrink-0" do %>
          <div class="w-5 h-5 rounded border-2 flex items-center justify-center cursor-pointer
            <%= todo.complete? ? 'bg-violet-500 border-violet-500' : 'border-app-border hover:border-app-primary' %>">
            <% if todo.complete? %>
              <svg class="w-3 h-3 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
            <% end %>
          </div>
        <% end %>
        <span class="flex-1 <%= todo.complete? ? 'line-through text-app-faint' : 'text-app-text' %>">
          <%= todo.title %>
        </span>
        <% if todo.due_date %>
          <span class="text-xs text-app-faint"><%= todo.due_date.strftime("%b %-d") %></span>
        <% end %>
        <%= link_to "Edit", edit_todo_path(todo), class: "text-xs text-app-faint hover:text-app-text" %>
      </div>
    <% end %>
  </div>
<% else %>
  <%= render "shared/empty_state", message: "No todos yet." %>
<% end %>

<%= render "notes/notes", notable: @project %>
