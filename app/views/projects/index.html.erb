<% pastel_cards = %w[bg-card-3 bg-card-6 bg-card-1 bg-card-5 bg-card-2 bg-card-4] %>
<% card_texts = %w[text-card-text-3 text-card-text-6 text-card-text-1 text-card-text-5 text-card-text-2 text-card-text-4] %>

<div class="flex items-center justify-between mb-8">
  <h1 class="text-3xl font-bold text-app-text">Projects</h1>
  <%= link_to "New project", new_project_path, class: primary_button_class("inline-flex items-center gap-1 px-4 py-2 text-sm") %>
</div>

<% if @projects.any? %>
  <div class="relative" data-testid="active-projects">
    <% @projects.each_with_index do |project, i| %>
      <% card_bg = pastel_cards[i % pastel_cards.length] %>
      <% card_text = card_texts[i % card_texts.length] %>
      <%= link_to project_path(project), class: "group block #{card_bg} rounded-2xl p-5 shadow-sm hover:shadow-md transition-all duration-300 hover:-translate-y-1 #{i > 0 ? '-mt-3' : ''} relative", style: "z-index: #{i + 1}" do %>
        <div class="flex items-center justify-between">
          <div class="flex-1 min-w-0">
            <h2 class="font-bold text-lg <%= card_text %>"><%= [project.emoji, project.title].compact.join(" ") %></h2>
            <div class="flex items-center gap-2 mt-1">
              <% if project.goal %>
                <span class="text-xs bg-app-surface/55 rounded-full px-2 py-0.5 <%= card_text %> opacity-80"><%= [project.goal.emoji, project.goal.title].compact.join(" ") %></span>
              <% end %>
              <% total = project.todos.count %>
              <% completed = project.todos.where.not(completed_at: nil).count %>
              <% if total > 0 %>
                <span class="text-xs bg-app-surface/55 rounded-full px-2 py-0.5 <%= card_text %> opacity-80"><%= completed %>/<%= total %> todos</span>
              <% end %>
              <% unless project.active? %>
                <span class="text-xs px-2 py-0.5 rounded-full bg-app-surface/45 <%= card_text %> opacity-75">
                  <%= project.status.capitalize %>
                </span>
              <% end %>
            </div>
          </div>
          <div class="flex items-center gap-3">
            <% project_members = ([project.user] + project.members.to_a).uniq %>
            <% if project_members.size > 1 %>
              <%= avatar_stack(project_members, size: :xs, max: 3) %>
            <% end %>
            <div class="hidden sm:block">
              <%= render "shared/momentum", record: project %>
            </div>
            <svg class="w-5 h-5 <%= card_text %> opacity-65 group-hover:opacity-100 transition-opacity" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </div>
        </div>

        <%# Expand on hover %>
        <div class="max-h-0 overflow-hidden group-hover:max-h-40 transition-all duration-300 ease-in-out">
          <div class="pt-3 mt-3 border-t border-app-surface/40">
            <% if project.description.present? %>
              <p class="text-sm <%= card_text %> opacity-80 mb-2"><%= truncate(project.description, length: 120) %></p>
            <% end %>
            <div class="flex justify-end mt-1">
              <%= render "shared/sparkline", record: project %>
            </div>
          </div>
        </div>
      <% end %>
    <% end %>
  </div>
<% else %>
  <%= render "shared/empty_state", message: "No active projects. Create one to get started." %>
<% end %>

<% if @show_all && @inactive_projects.any? %>
  <section class="mt-10" data-testid="inactive-projects">
    <div class="flex items-center justify-between mb-3">
      <h2 class="text-sm font-semibold text-app-muted uppercase">Completed &amp; archived</h2>
      <span class="text-xs text-app-faint"><%= pluralize(@inactive_projects.size, "project") %></span>
    </div>

    <div class="overflow-hidden rounded-lg border border-app-border bg-app-surface">
      <table class="w-full text-sm">
        <tbody class="divide-y divide-app-border">
          <% @inactive_projects.each do |project| %>
            <% status_classes = project.archived? ? "bg-app-surface-muted text-app-muted" : "bg-app-success-soft text-app-success" %>
            <tr class="hover:bg-app-surface-muted transition-colors">
              <td class="py-3 pl-4 pr-3 align-middle">
                <%= link_to project_path(project), class: "flex items-center gap-3 min-w-0" do %>
                  <span class="text-base shrink-0"><%= project.emoji.presence || "📁" %></span>
                  <span class="font-medium text-app-text truncate"><%= project.title %></span>
                <% end %>
              </td>
              <td class="hidden sm:table-cell px-3 py-3 text-app-muted align-middle">
                <% if project.goal %>
                  <span class="inline-flex max-w-52 items-center rounded-full bg-app-surface-muted px-2 py-0.5 text-xs text-app-muted">
                    <span class="truncate"><%= [project.goal.emoji, project.goal.title].compact.join(" ") %></span>
                  </span>
                <% end %>
              </td>
              <td class="py-3 pl-3 pr-4 text-right align-middle">
                <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium <%= status_classes %>">
                  <%= project.status.capitalize %>
                </span>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>
<% end %>

<%# Show/hide completed & archived footer %>
<% if @show_all %>
  <div class="mt-6 text-center">
    <%= link_to projects_path, class: "text-sm text-app-faint hover:text-app-muted transition-colors" do %>
      Hide completed &amp; archived
    <% end %>
  </div>
<% elsif @inactive_count&.positive? %>
  <div class="mt-6 text-center">
    <%= link_to projects_path(show_all: 1), class: "text-sm text-app-faint hover:text-app-muted transition-colors" do %>
      Show completed &amp; archived (<%= @inactive_count %>)
    <% end %>
  </div>
<% end %>
