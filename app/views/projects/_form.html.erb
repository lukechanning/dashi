<%= form_with model: project, class: "space-y-4" do |f| %>
  <%= render "shared/error_messages", model: project %>
  <%= hidden_field_tag :from_todo, @from_todo if @from_todo.present? %>

  <div class="flex gap-3">
    <div class="w-20 flex-shrink-0">
      <%= f.label :emoji, "Emoji", class: form_label_class %>
      <%= f.text_field :emoji, placeholder: "📌",
          class: form_control_class("text-center text-xl") %>
    </div>
    <div class="flex-1">
      <%= f.label :title, class: form_label_class %>
      <%= f.text_field :title, required: true, autofocus: true,
          class: form_control_class %>
    </div>
  </div>

  <div>
    <%= f.label :description, class: form_label_class %>
    <%= f.text_area :description, rows: 3,
        class: form_control_class %>
  </div>

  <div>
    <%= f.label :goal_id, "Goal (optional)", class: form_label_class %>
    <%= f.collection_select :goal_id, current_user.goals.active.ordered, :id, :title,
        { include_blank: "None (standalone project)" },
        class: form_control_class("w-auto") %>
  </div>

  <% if project.persisted? %>
    <div>
      <%= f.label :status, class: form_label_class %>
      <%= f.select :status, Project.statuses.keys.map { |s| [s.capitalize, s] },
          {}, class: form_control_class("w-auto") %>
    </div>
  <% end %>

  <div class="flex items-center gap-3">
    <%= f.submit class: primary_button_class("text-sm") %>
    <%= link_to "Cancel", project.persisted? ? project_path(project) : projects_path, class: muted_link_class("text-sm") %>
  </div>
<% end %>
