<div class="min-h-screen flex items-center justify-center">
  <div class="w-full max-w-sm">
    <div class="flex flex-col items-center gap-3 mb-8">
      <%= render "shared/logo", size: :lg %>
      <h1 class="text-2xl font-bold tracking-tight">Sign in to Dashi</h1>
    </div>

    <% if flash[:notice] %>
      <div class="bg-app-success-soft border border-app-success text-app-success rounded-xl p-4 mb-6">
        <%= flash[:notice] %>
      </div>
    <% end %>

    <% if flash[:alert] %>
      <div class="bg-app-danger-soft border border-app-danger text-app-danger rounded-xl p-4 mb-6">
        <%= flash[:alert] %>
      </div>
    <% end %>

    <%= form_with url: session_path, method: :post, class: "space-y-4" do |f| %>
      <div>
        <%= f.label :email, "Email address", class: form_label_class %>
        <%= f.email_field :email, required: true, autofocus: true, placeholder: "you@example.com",
            class: form_control_class %>
      </div>

      <%= f.submit "Send sign-in link", class: primary_button_class("w-full") %>
    <% end %>
  </div>
</div>
