<div class="min-h-screen flex items-center justify-center">
  <div class="w-full max-w-sm">
    <div class="flex flex-col items-center gap-3 mb-8">
      <%= render "shared/logo", size: :lg %>
      <h1 class="text-2xl font-bold tracking-tight">Welcome to Dashi</h1>
      <p class="text-app-muted text-sm text-center">Create your admin account to get started.</p>
    </div>

    <% if @user.errors.any? %>
      <div class="bg-app-danger-soft border border-app-danger text-app-danger rounded-xl p-4 mb-6">
        <ul class="list-disc list-inside space-y-1 text-sm">
          <% @user.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= form_with model: @user, url: setup_path, method: :post, class: "space-y-4" do |f| %>
      <div>
        <%= f.label :name, "Your name", class: form_label_class %>
        <%= f.text_field :name, required: true, autofocus: true, placeholder: "Ada Lovelace",
            class: form_control_class %>
      </div>

      <div>
        <%= f.label :email, "Email address", class: form_label_class %>
        <%= f.email_field :email, required: true, placeholder: "you@example.com",
            class: form_control_class %>
      </div>

      <%= f.submit "Create admin account", class: primary_button_class("w-full") %>
    <% end %>
  </div>
</div>
