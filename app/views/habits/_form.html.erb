<%= form_with model: habit, class: "space-y-4", data: { controller: "habit-form" } do |f| %>
  <%= render "shared/error_messages", model: habit %>

  <div>
    <%= f.label :title, class: form_label_class %>
    <%= f.text_field :title, required: true, autofocus: true,
        placeholder: "e.g., Walk the dog",
        class: form_control_class %>
  </div>

  <div>
    <%= f.label :frequency, class: form_label_class %>
    <%= f.select :frequency, Habit.frequencies.keys.map { |s| [frequency_label(s), s] },
        {}, class: form_control_class,
        data: { habit_form_target: "frequency", action: "habit-form#toggle" } %>
  </div>

  <div data-habit-form-target="customDays" class="<%= 'hidden' unless habit.custom? %>">
    <span class="<%= form_label_class %>">Days of the week</span>
    <div class="flex flex-wrap gap-2">
      <% Date::ABBR_DAYNAMES.each_with_index do |name, i| %>
        <label class="inline-flex items-center gap-1.5 bg-app-surface-muted rounded-lg px-3 py-1.5 cursor-pointer hover:opacity-85 transition-colors">
          <%= check_box_tag "habit[days_of_week][]", i,
              habit.days_of_week.to_s.split(",").include?(i.to_s),
              id: "habit_days_of_week_#{i}",
              class: "rounded border-app-border text-violet-600 focus:ring-violet-500" %>
          <span class="text-sm text-app-text"><%= name %></span>
        </label>
      <% end %>
    </div>
  </div>

  <div>
    <%= f.label :project_id, "Project (optional)", class: form_label_class %>
    <%= f.select :project_id,
        current_user.projects.active.ordered.map { |p| [[p.emoji, p.title].compact.join(" "), p.id] },
        { include_blank: "None" },
        class: form_control_class %>
  </div>

  <div>
    <%= f.label :start_date, class: form_label_class %>
    <%= f.date_field :start_date,
        value: habit.start_date || Date.current,
        class: form_control_class %>
  </div>

  <div class="flex items-center gap-3">
    <%= f.submit class: primary_button_class("text-sm") %>
    <%= link_to "Cancel", habits_path, class: muted_link_class("text-sm") %>
  </div>
<% end %>
