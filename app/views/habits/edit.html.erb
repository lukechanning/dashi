<h1 class="text-2xl font-bold text-app-text mb-6">Edit habit</h1>
<%= render "form", habit: @habit %>

<div class="mt-6 pt-6 border-t border-app-border">
  <%= button_to "Delete this habit", habit_path(@habit), method: :delete,
      data: { turbo_confirm: "Are you sure you want to delete this habit?" },
      class: "text-sm text-app-danger hover:opacity-80 cursor-pointer" %>
</div>
