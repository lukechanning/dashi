<% dot_class, text_class, label = case record.momentum
  when :hot  then ["bg-app-success", "text-app-success", "Active"]
  when :warm then ["bg-app-warning", "text-app-warning", "In progress"]
  when :cool then ["bg-app-faint",   "text-app-muted",   "Gone quiet"]
  when :new  then ["bg-app-primary", "text-app-primary", "Just started"]
  end %>
<div class="flex items-center gap-1.5">
  <span class="w-2 h-2 rounded-full <%= dot_class %> inline-block"></span>
  <span class="text-xs <%= text_class %>"><%= label %></span>
</div>
