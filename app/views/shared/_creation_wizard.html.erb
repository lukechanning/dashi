<%# Unified creation wizard — fixed overlay, hidden by default. Opened by creation-wizard#open from body controller. %>
<%# Locals: wizard_projects (Array), wizard_goals (Array) — preloaded by ApplicationController#set_wizard_data %>
<div
  data-creation-wizard-target="overlay"
  class="hidden fixed inset-0 z-50 bg-stone-900/60 backdrop-blur-sm"
>
  <div class="flex items-center justify-center h-full">
  <div class="bg-white rounded-3xl shadow-2xl w-full max-w-lg mx-4 flex flex-col max-h-[90vh] overflow-hidden">

    <%# Header: back button + title + close %>
    <div class="flex items-center justify-between px-6 pt-6 pb-4 border-b border-stone-100">
      <button
        data-action="creation-wizard#back"
        data-creation-wizard-target="backBtn"
        class="hidden text-stone-400 hover:text-stone-600 transition-colors cursor-pointer p-1 rounded-lg hover:bg-stone-100"
        aria-label="Go back"
      >
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
      </button>
      <h2 data-creation-wizard-target="stepTitle" class="text-lg font-semibold text-stone-800 flex-1 text-center">What are you creating?</h2>
      <button
        data-action="creation-wizard#close"
        class="text-stone-400 hover:text-stone-600 transition-colors cursor-pointer p-1 rounded-lg hover:bg-stone-100"
        aria-label="Close"
      >
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <%# Scrollable step content %>
    <div class="overflow-y-auto flex-1">

      <%# ─────────────────────────────────────────────────── %>
      <%# STEP: type — choose what to create %>
      <%# ─────────────────────────────────────────────────── %>
      <div data-creation-wizard-target="step" data-step-name="type" class="p-6">
        <div class="grid grid-cols-2 gap-3">

          <%# Task %>
          <button
            data-action="creation-wizard#selectType"
            data-creation-wizard-type-param="task"
            class="flex flex-col items-center gap-3 bg-stone-50 hover:bg-violet-50 border-2 border-stone-200 hover:border-violet-300 rounded-2xl p-5 transition-all cursor-pointer group"
          >
            <div class="w-12 h-12 rounded-xl bg-violet-100 group-hover:bg-violet-200 flex items-center justify-center transition-colors">
              <svg class="w-6 h-6 text-violet-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
              </svg>
            </div>
            <div class="text-center">
              <p class="font-semibold text-stone-800">Task</p>
              <p class="text-xs text-stone-500 mt-0.5">A single to-do</p>
            </div>
          </button>

          <%# Project %>
          <button
            data-action="creation-wizard#selectType"
            data-creation-wizard-type-param="project"
            class="flex flex-col items-center gap-3 bg-stone-50 hover:bg-violet-50 border-2 border-stone-200 hover:border-violet-300 rounded-2xl p-5 transition-all cursor-pointer group"
          >
            <div class="w-12 h-12 rounded-xl bg-blue-100 group-hover:bg-blue-200 flex items-center justify-center transition-colors">
              <svg class="w-6 h-6 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z" />
              </svg>
            </div>
            <div class="text-center">
              <p class="font-semibold text-stone-800">Project</p>
              <p class="text-xs text-stone-500 mt-0.5">Medium-term work</p>
            </div>
          </button>

          <%# Goal %>
          <button
            data-action="creation-wizard#selectType"
            data-creation-wizard-type-param="goal"
            class="flex flex-col items-center gap-3 bg-stone-50 hover:bg-violet-50 border-2 border-stone-200 hover:border-violet-300 rounded-2xl p-5 transition-all cursor-pointer group"
          >
            <div class="w-12 h-12 rounded-xl bg-amber-100 group-hover:bg-amber-200 flex items-center justify-center transition-colors">
              <svg class="w-6 h-6 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
              </svg>
            </div>
            <div class="text-center">
              <p class="font-semibold text-stone-800">Goal</p>
              <p class="text-xs text-stone-500 mt-0.5">Long-term aspiration</p>
            </div>
          </button>

          <%# Chain %>
          <button
            data-action="creation-wizard#selectType"
            data-creation-wizard-type-param="chain"
            class="flex flex-col items-center gap-3 bg-stone-50 hover:bg-violet-50 border-2 border-stone-200 hover:border-violet-300 rounded-2xl p-5 transition-all cursor-pointer group"
          >
            <div class="w-12 h-12 rounded-xl bg-emerald-100 group-hover:bg-emerald-200 flex items-center justify-center transition-colors">
              <svg class="w-6 h-6 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
              </svg>
            </div>
            <div class="text-center">
              <p class="font-semibold text-stone-800">Chain</p>
              <p class="text-xs text-stone-500 mt-0.5">Sequential steps</p>
            </div>
          </button>
        </div>
      </div>

      <%# ─────────────────────────────────────────────────── %>
      <%# STEP: task %>
      <%# ─────────────────────────────────────────────────── %>
      <div
        data-controller="wizard-task-form"
        data-creation-wizard-target="step"
        data-step-name="task"
        class="hidden p-6 space-y-4"
      >
        <div>
          <label class="block text-sm font-medium text-stone-700 mb-1">What needs to get done?</label>
          <input
            data-wizard-task-form-target="title"
            type="text"
            placeholder="e.g. Review quarterly goals"
            class="w-full rounded-xl border border-stone-300 px-4 py-3 text-stone-800 placeholder:text-stone-400 focus:ring-2 focus:ring-violet-500 focus:border-transparent outline-none transition"
            autocomplete="off"
          >
        </div>
        <div>
          <label class="block text-sm font-medium text-stone-700 mb-1">Due date</label>
          <input
            data-wizard-task-form-target="dueDate"
            type="date"
            value="<%= Date.current %>"
            class="w-full rounded-xl border border-stone-300 px-4 py-3 text-stone-800 focus:ring-2 focus:ring-violet-500 focus:border-transparent outline-none transition"
            autocomplete="off"
          >
        </div>
        <div>
          <label class="block text-sm font-medium text-stone-700 mb-1">Project <span class="text-stone-400 font-normal">(optional)</span></label>
          <select
            data-wizard-task-form-target="project"
            class="w-full rounded-xl border border-stone-300 px-4 py-3 text-stone-800 focus:ring-2 focus:ring-violet-500 focus:border-transparent outline-none transition bg-white"
            autocomplete="off"
          >
            <option value="">No project</option>
            <% wizard_projects.each do |project| %>
              <option value="<%= project.id %>"><%= [project.emoji, project.title].compact.join(" ") %></option>
            <% end %>
          </select>
        </div>
        <button
          data-action="wizard-task-form#submit"
          class="w-full bg-violet-600 hover:bg-violet-700 text-white font-semibold rounded-xl px-6 py-3 transition-colors cursor-pointer"
        >
          Add task
        </button>
      </div>

      <%# ─────────────────────────────────────────────────── %>
      <%# STEP: project %>
      <%# ─────────────────────────────────────────────────── %>
      <div
        data-controller="wizard-project-form"
        data-creation-wizard-target="step"
        data-step-name="project"
        class="hidden p-6 space-y-4"
      >
        <div class="flex gap-3">
          <div class="w-14 shrink-0">
            <label class="block text-sm font-medium text-stone-700 mb-1">Icon</label>
            <input
              data-wizard-project-form-target="emoji"
              type="text"
              placeholder="📁"
              maxlength="2"
              class="w-full rounded-xl border border-stone-300 px-2 py-3 text-center text-xl focus:ring-2 focus:ring-violet-500 focus:border-transparent outline-none transition"
              autocomplete="off"
            >
          </div>
          <div class="flex-1">
            <label class="block text-sm font-medium text-stone-700 mb-1">Project name</label>
            <input
              data-wizard-project-form-target="title"
              type="text"
              placeholder="e.g. Website redesign"
              class="w-full rounded-xl border border-stone-300 px-4 py-3 text-stone-800 placeholder:text-stone-400 focus:ring-2 focus:ring-violet-500 focus:border-transparent outline-none transition"
              autocomplete="off"
            >
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium text-stone-700 mb-1">Description <span class="text-stone-400 font-normal">(optional)</span></label>
          <textarea
            data-wizard-project-form-target="description"
            rows="2"
            placeholder="What's this project about?"
            class="w-full rounded-xl border border-stone-300 px-4 py-3 text-stone-800 placeholder:text-stone-400 focus:ring-2 focus:ring-violet-500 focus:border-transparent outline-none transition resize-none"
            autocomplete="off"
          ></textarea>
        </div>
        <div>
          <label class="block text-sm font-medium text-stone-700 mb-1">Goal <span class="text-stone-400 font-normal">(optional)</span></label>
          <select
            data-wizard-project-form-target="goal"
            class="w-full rounded-xl border border-stone-300 px-4 py-3 text-stone-800 focus:ring-2 focus:ring-violet-500 focus:border-transparent outline-none transition bg-white"
            autocomplete="off"
          >
            <option value="">No goal</option>
            <% wizard_goals.each do |goal| %>
              <option value="<%= goal.id %>"><%= [goal.emoji, goal.title].compact.join(" ") %></option>
            <% end %>
          </select>
        </div>
        <button
          data-action="wizard-project-form#submit"
          class="w-full bg-violet-600 hover:bg-violet-700 text-white font-semibold rounded-xl px-6 py-3 transition-colors cursor-pointer"
        >
          Create project
        </button>
      </div>

      <%# ─────────────────────────────────────────────────── %>
      <%# STEP: goal %>
      <%# ─────────────────────────────────────────────────── %>
      <div
        data-controller="wizard-goal-form"
        data-creation-wizard-target="step"
        data-step-name="goal"
        class="hidden p-6 space-y-4"
      >
        <div class="flex gap-3">
          <div class="w-14 shrink-0">
            <label class="block text-sm font-medium text-stone-700 mb-1">Icon</label>
            <input
              data-wizard-goal-form-target="emoji"
              type="text"
              placeholder="🎯"
              maxlength="2"
              class="w-full rounded-xl border border-stone-300 px-2 py-3 text-center text-xl focus:ring-2 focus:ring-violet-500 focus:border-transparent outline-none transition"
              autocomplete="off"
            >
          </div>
          <div class="flex-1">
            <label class="block text-sm font-medium text-stone-700 mb-1">Goal name</label>
            <input
              data-wizard-goal-form-target="title"
              type="text"
              placeholder="e.g. Get fit"
              class="w-full rounded-xl border border-stone-300 px-4 py-3 text-stone-800 placeholder:text-stone-400 focus:ring-2 focus:ring-violet-500 focus:border-transparent outline-none transition"
              autocomplete="off"
            >
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium text-stone-700 mb-1">Description <span class="text-stone-400 font-normal">(optional)</span></label>
          <textarea
            data-wizard-goal-form-target="description"
            rows="2"
            placeholder="Why does this matter to you?"
            class="w-full rounded-xl border border-stone-300 px-4 py-3 text-stone-800 placeholder:text-stone-400 focus:ring-2 focus:ring-violet-500 focus:border-transparent outline-none transition resize-none"
            autocomplete="off"
          ></textarea>
        </div>
        <button
          data-action="wizard-goal-form#submit"
          class="w-full bg-violet-600 hover:bg-violet-700 text-white font-semibold rounded-xl px-6 py-3 transition-colors cursor-pointer"
        >
          Create goal
        </button>
      </div>

      <%# ─────────────────────────────────────────────────── %>
      <%# STEPS: chain (name → step builder → review) %>
      <%# All three are wrapped so wizard-chain has a single root element. %>
      <%# ─────────────────────────────────────────────────── %>
      <div data-controller="wizard-chain">

        <%# Chain: name step %>
        <div data-creation-wizard-target="step" data-step-name="chainName" class="hidden p-6 space-y-4">
          <p class="text-sm text-stone-500">A chain is an ordered sequence of tasks or projects. Complete one to unlock scheduling the next.</p>
          <div class="flex gap-3">
            <div class="w-14 shrink-0">
              <label class="block text-sm font-medium text-stone-700 mb-1">Icon</label>
              <input
                data-wizard-chain-target="emoji"
                type="text"
                placeholder="🔗"
                maxlength="2"
                class="w-full rounded-xl border border-stone-300 px-2 py-3 text-center text-xl focus:ring-2 focus:ring-violet-500 focus:border-transparent outline-none transition"
                autocomplete="off"
              >
            </div>
            <div class="flex-1">
              <label class="block text-sm font-medium text-stone-700 mb-1">Chain name</label>
              <input
                data-wizard-chain-target="title"
                type="text"
                placeholder="e.g. Morning Routine"
                class="w-full rounded-xl border border-stone-300 px-4 py-3 text-stone-800 placeholder:text-stone-400 focus:ring-2 focus:ring-violet-500 focus:border-transparent outline-none transition"
                autocomplete="off"
              >
            </div>
          </div>
          <button
            data-action="wizard-chain#goToAddStep"
            class="w-full bg-violet-600 hover:bg-violet-700 text-white font-semibold rounded-xl px-6 py-3 transition-colors cursor-pointer"
          >
            Add steps →
          </button>
        </div>

        <%# Chain: step builder %>
        <div data-creation-wizard-target="step" data-step-name="chainStep" class="hidden p-6 space-y-4">
          <div data-wizard-chain-target="stepCounter" class="text-xs font-semibold text-violet-600 uppercase tracking-wide">Step 1</div>
          <div>
            <label class="block text-sm font-medium text-stone-700 mb-2">Type</label>
            <div class="flex gap-2">
              <label class="flex-1 flex items-center gap-2 border-2 border-stone-200 rounded-xl px-4 py-3 cursor-pointer hover:border-violet-300 transition-colors has-[:checked]:bg-violet-50">
                <input
                  type="radio"
                  name="step_item_type"
                  value="todo"
                  data-wizard-chain-target="itemType"
                  data-action="wizard-chain#itemTypeChanged"
                  class="accent-violet-600"
                  checked
                  autocomplete="off"
                >
                <span class="font-medium text-stone-800">Task</span>
              </label>
              <label class="flex-1 flex items-center gap-2 border-2 border-stone-200 rounded-xl px-4 py-3 cursor-pointer hover:border-violet-300 transition-colors has-[:checked]:bg-violet-50">
                <input
                  type="radio"
                  name="step_item_type"
                  value="project"
                  data-wizard-chain-target="itemType"
                  data-action="wizard-chain#itemTypeChanged"
                  class="accent-violet-600"
                  autocomplete="off"
                >
                <span class="font-medium text-stone-800">Project</span>
              </label>
            </div>
          </div>
          <div class="flex gap-3">
            <div data-wizard-chain-target="emojiWrapper" class="hidden w-14 shrink-0">
              <label class="block text-sm font-medium text-stone-700 mb-1">Icon</label>
              <input
                data-wizard-chain-target="stepEmoji"
                type="text"
                placeholder="📁"
                maxlength="2"
                class="w-full rounded-xl border border-stone-300 px-2 py-3 text-center text-xl focus:ring-2 focus:ring-violet-500 focus:border-transparent outline-none transition"
                autocomplete="off"
              >
            </div>
            <div class="flex-1">
              <label class="block text-sm font-medium text-stone-700 mb-1">Title</label>
              <input
                data-wizard-chain-target="stepTitle"
                type="text"
                placeholder="e.g. Read for 30 minutes"
                class="w-full rounded-xl border border-stone-300 px-4 py-3 text-stone-800 placeholder:text-stone-400 focus:ring-2 focus:ring-violet-500 focus:border-transparent outline-none transition"
                autocomplete="off"
              >
            </div>
          </div>
          <div>
            <label class="block text-sm font-medium text-stone-700 mb-1">Description <span class="text-stone-400 font-normal">(optional)</span></label>
            <input
              data-wizard-chain-target="stepDescription"
              type="text"
              placeholder="Any extra details"
              class="w-full rounded-xl border border-stone-300 px-4 py-3 text-stone-800 placeholder:text-stone-400 focus:ring-2 focus:ring-violet-500 focus:border-transparent outline-none transition"
              autocomplete="off"
            >
          </div>
          <div data-wizard-chain-target="dueDateWrapper">
            <label class="block text-sm font-medium text-stone-700 mb-1">Start date <span class="text-stone-400 font-normal">(when should this begin?)</span></label>
            <input
              data-wizard-chain-target="dueDate"
              type="date"
              value="<%= Date.current %>"
              class="w-full rounded-xl border border-stone-300 px-4 py-3 text-stone-800 focus:ring-2 focus:ring-violet-500 focus:border-transparent outline-none transition"
              autocomplete="off"
            >
          </div>
          <button
            data-action="wizard-chain#addStep"
            class="w-full bg-violet-600 hover:bg-violet-700 text-white font-semibold rounded-xl px-6 py-3 transition-colors cursor-pointer"
          >
            Save step
          </button>
        </div>

        <%# Chain: review %>
        <div data-creation-wizard-target="step" data-step-name="chainReview" class="hidden p-6 space-y-4">
          <div>
            <h3 data-wizard-chain-target="reviewTitle" class="font-semibold text-stone-800 mb-3"></h3>
            <ol data-wizard-chain-target="previewList" class="space-y-2">
              <%# Populated dynamically by wizard-chain controller %>
            </ol>
          </div>
          <div class="flex flex-col gap-2">
            <button
              data-action="wizard-chain#addAnotherStep"
              class="w-full border-2 border-stone-200 hover:border-violet-300 text-stone-700 hover:text-violet-700 font-semibold rounded-xl px-6 py-3 transition-colors cursor-pointer"
            >
              + Add another step
            </button>
            <button
              data-action="wizard-chain#submitChain"
              class="w-full bg-violet-600 hover:bg-violet-700 text-white font-semibold rounded-xl px-6 py-3 transition-colors cursor-pointer"
            >
              Create chain ✓
            </button>
          </div>
        </div>

      </div><%# end wizard-chain %>

      <%# ─────────────────────────────────────────────────── %>
      <%# STATE: submitting — loading indicator %>
      <%# ─────────────────────────────────────────────────── %>
      <div data-creation-wizard-target="step" data-step-name="submitting" class="hidden p-12">
        <div class="flex flex-col items-center gap-4">
          <div class="w-10 h-10 border-4 border-violet-200 border-t-violet-600 rounded-full animate-spin"></div>
          <p class="text-stone-500 text-sm">Creating…</p>
        </div>
      </div>

    </div>
  </div>
  </div>
</div>
