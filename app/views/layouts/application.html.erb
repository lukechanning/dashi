<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Dashi" %></title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body class="<%= app_body_class %>"
        data-controller="timezone creation-wizard"
        data-timezone-current-value="<%= current_user&.timezone.to_s %>">
    <nav class="bg-app-surface/90 backdrop-blur-sm border-b border-app-border">
      <div class="max-w-4xl mx-auto px-4 py-3 flex items-center justify-between">
        <%= link_to root_path, class: "flex items-center gap-2" do %>
          <%= render "shared/logo", size: :sm %>
          <span class="text-lg font-bold tracking-tight text-app-text">Dashi</span>
        <% end %>

        <%# Desktop links (hidden on mobile — AppBar handles mobile nav) %>
        <div class="hidden sm:flex items-center gap-4 text-sm">
          <%= link_to "Today", root_path, class: muted_link_class("transition-colors") %>
          <%= link_to "Projects", projects_path, class: muted_link_class("transition-colors") %>
          <%= link_to "Goals", goals_path, class: muted_link_class("transition-colors") %>
          <%= link_to "Habits", habits_path, class: muted_link_class("transition-colors") %>
          <%= link_to "Notes", notes_index_path, class: muted_link_class("transition-colors") %>
          <% if current_user&.admin? %>
            <%= link_to "Invitations", invitations_path, class: muted_link_class("transition-colors") %>
          <% end %>
          <span class="text-app-faint">|</span>
          <%= link_to account_path, class: "flex items-center gap-2 hover:opacity-80 transition-opacity" do %>
            <%= user_avatar(current_user, size: :sm) %>
            <span class="text-app-muted"><%= current_user.name %></span>
          <% end %>
          <%= button_to "Sign out", session_path, method: :delete, class: "text-app-faint hover:text-app-muted cursor-pointer transition-colors" %>
        </div>
      </div>
    </nav>

    <%# Main content — extra bottom padding on mobile to clear the AppBar %>
    <main class="max-w-4xl mx-auto px-4 py-8 pb-28 sm:pb-8">
      <% if flash[:notice] %>
        <div class="bg-app-success-soft border border-app-success text-app-success rounded-lg p-3 mb-6 text-sm">
          <%= flash[:notice] %>
        </div>
      <% end %>

      <% if flash[:alert] %>
        <div class="bg-app-danger-soft border border-app-danger text-app-danger rounded-lg p-3 mb-6 text-sm">
          <%= flash[:alert] %>
        </div>
      <% end %>

      <% if flash[:celebration] %>
        <%= render "shared/celebration_banner", message: flash[:celebration] %>
      <% end %>

      <%= yield %>
    </main>

    <%# Bottom AppBar (mobile + tablet) %>
    <% if current_user %>
      <%= render "shared/creation_wizard", wizard_projects: @wizard_projects, wizard_goals: @wizard_goals %>

      <div class="sm:hidden">
        <%= render "shared/app_bar" %>
      </div>

      <%# Floating action button (desktop only) — opens the creation wizard %>
      <button
        id="fab-create"
        data-action="creation-wizard#open"
        class="hidden sm:flex items-center justify-center fixed bottom-6 right-6 w-14 h-14 bg-violet-600 hover:bg-violet-700 active:bg-violet-800 text-white rounded-full shadow-lg hover:shadow-xl transition-all duration-150 z-40 cursor-pointer"
        title="Create something"
        aria-label="Create"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
        </svg>
      </button>
    <% end %>
  </body>
</html>
