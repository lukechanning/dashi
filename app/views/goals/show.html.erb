<div class="mb-6">
  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-bold text-app-text"><%= [@goal.emoji, @goal.title].compact.join(" ") %></h1>
    <div class="flex items-center gap-2">
      <%= link_to "Edit", edit_goal_path(@goal), class: muted_link_class("text-sm") %>
      <%= button_to "Delete", goal_path(@goal), method: :delete,
          data: { turbo_confirm: "Delete this goal and all its projects?" },
          class: "text-sm text-app-danger hover:opacity-80 cursor-pointer" %>
    </div>
  </div>

  <% if @goal.description.present? %>
    <p class="text-app-muted mt-2"><%= @goal.description %></p>
  <% end %>

  <div class="flex items-center gap-2 mt-3">
    <% if @goal.active? %>
      <%= button_to "Mark complete", goal_path(@goal), method: :patch,
          params: { goal: { status: "completed" } },
          class: "px-3 py-1.5 text-sm font-medium bg-app-success-soft text-app-success rounded-xl hover:opacity-85 transition-colors cursor-pointer" %>
      <%= button_to "Archive", goal_path(@goal), method: :patch,
          params: { goal: { status: "archived" } },
          data: { turbo_confirm: "Archive this goal and all its projects?" },
          class: "px-3 py-1.5 text-sm font-medium bg-app-danger-soft text-app-danger rounded-xl hover:opacity-85 transition-colors cursor-pointer" %>
    <% else %>
      <span class="text-xs px-2 py-1 rounded-full bg-app-surface-muted text-app-muted font-medium">
        <%= @goal.status.capitalize %>
      </span>
      <%= button_to "Reactivate", goal_path(@goal), method: :patch,
          params: { goal: { status: "active" } },
          class: primary_button_class("px-3 py-1.5 text-sm") %>
    <% end %>
  </div>
  <div class="mt-4">
    <%= render "shared/contribution_graph", record: @goal %>
  </div>
</div>

<%= render "shared/members_section", memberable: @goal %>

<div class="flex items-center justify-between mb-4">
  <h2 class="text-lg font-semibold text-app-text">Projects</h2>
  <%= link_to "New project", new_project_path(goal_id: @goal.id), class: "text-sm text-app-primary hover:opacity-85" %>
</div>

<% if @projects.any? %>
  <div class="space-y-3">
    <% @projects.each do |project| %>
      <%= link_to project_path(project), class: "#{card_class('block p-4')} hover:border-app-muted transition" do %>
        <div class="flex items-center justify-between">
          <h3 class="font-medium text-app-text"><%= [project.emoji, project.title].compact.join(" ") %></h3>
          <div class="flex items-center gap-3">
            <% members = ([project.user] + project.members.to_a).uniq %>
            <% if members.size > 1 %>
              <%= avatar_stack(members, size: :xs, max: 3) %>
            <% end %>
            <%= render "shared/momentum", record: project %>
          </div>
        </div>
      <% end %>
    <% end %>
  </div>
<% elsif !@show_all_projects %>
  <div class="text-center py-8 text-app-muted text-sm">
    <p>No active projects yet.</p>
  </div>
<% end %>

<% if @show_all_projects %>
  <div class="mt-4 text-center">
    <%= link_to goal_path(@goal), class: "text-sm text-app-faint hover:text-app-muted transition-colors" do %>
      Hide completed &amp; archived projects
    <% end %>
  </div>
<% elsif @inactive_projects_count&.positive? %>
  <div class="mt-4 text-center">
    <%= link_to goal_path(@goal, show_all: 1), class: "text-sm text-app-faint hover:text-app-muted transition-colors" do %>
      Show completed &amp; archived projects (<%= @inactive_projects_count %>)
    <% end %>
  </div>
<% end %>

<%= render "notes/notes", notable: @goal %>
