<div class="mb-8 flex items-center gap-4">
  <%= user_avatar(current_user, size: :lg) %>
  <div>
    <h1 class="text-2xl font-bold text-stone-800"><%= current_user.name %></h1>
    <p class="text-stone-500 text-sm"><%= current_user.email %></p>
  </div>
</div>

<div class="bg-white rounded-2xl border border-stone-200/60 shadow-sm divide-y divide-stone-100">
  <div class="p-5 flex items-center justify-between">
    <div>
      <p class="text-sm font-medium text-stone-700">Name</p>
      <p class="text-stone-500 text-sm mt-0.5"><%= current_user.name %></p>
    </div>
  </div>

  <div class="p-5 flex items-center justify-between">
    <div>
      <p class="text-sm font-medium text-stone-700">Email</p>
      <p class="text-stone-500 text-sm mt-0.5"><%= current_user.email %></p>
    </div>
  </div>

  <div class="p-5 flex items-center justify-between">
    <div>
      <p class="text-sm font-medium text-stone-700">Timezone</p>
      <p class="text-stone-500 text-sm mt-0.5"><%= current_user.timezone.presence || "Auto-detected" %></p>
    </div>
  </div>

  <% if current_user.admin? %>
    <div class="p-5 flex items-center justify-between">
      <div>
        <p class="text-sm font-medium text-stone-700">Role</p>
        <p class="text-sm mt-0.5">
          <span class="bg-violet-100 text-violet-700 rounded-full px-2 py-0.5 text-xs font-medium">Admin</span>
        </p>
      </div>
      <%= link_to "Manage Invitations", invitations_path, class: "text-sm text-violet-600 hover:text-violet-800 font-medium" %>
    </div>
  <% end %>
</div>

<div class="mt-8" data-controller="preferences">
  <div class="flex items-center justify-between mb-3">
    <h2 class="text-sm font-semibold text-stone-500 uppercase tracking-wide">Preferences</h2>
    <span class="text-xs text-green-600 opacity-0 transition-opacity duration-300" data-preferences-target="notice">✓ Saved</span>
  </div>
  <%= form_with model: current_user, url: account_path, method: :patch,
        data: { action: "turbo:submit-end->preferences#saved" } do |f| %>
    <div class="bg-white rounded-2xl border border-stone-200/60 shadow-sm divide-y divide-stone-100">

      <%# Stale tasks banner toggle %>
      <div class="p-5 flex items-center justify-between gap-4">
        <div>
          <p class="text-sm font-medium text-stone-700">Stale tasks banner</p>
          <p class="text-stone-500 text-sm mt-0.5">Remind me to review tasks that haven't been touched in a while</p>
        </div>
        <label class="relative inline-flex items-center cursor-pointer shrink-0">
          <%= f.check_box :show_stale_banner,
                class: "sr-only peer",
                data: { action: "change->preferences#staleBannerChanged" } %>
          <div class="w-11 h-6 bg-stone-200 rounded-full peer peer-checked:bg-violet-600 transition-colors after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:after:translate-x-5"></div>
        </label>
      </div>

      <%# Stale threshold — dims when stale banner is off %>
      <div class="p-5 flex items-center justify-between gap-4 transition-opacity"
           data-preferences-target="thresholdRow">
        <div>
          <p class="text-sm font-medium text-stone-700">Stale after</p>
          <p class="text-stone-500 text-sm mt-0.5">How many days before a task is considered stale</p>
        </div>
        <%= f.select :stale_threshold_days,
              options_for_select(
                User::STALE_THRESHOLD_OPTIONS.map { |d| ["#{d} days", d] },
                current_user.stale_threshold_days
              ),
              {},
              {
                class: "text-sm border border-stone-200 rounded-lg px-3 py-1.5 text-stone-700 bg-white focus:outline-none focus:ring-2 focus:ring-violet-500 focus:border-transparent shrink-0",
                data: { action: "change->preferences#save" }
              } %>
      </div>

      <%# Friday reflection banner toggle %>
      <div class="p-5 flex items-center justify-between gap-4">
        <div>
          <p class="text-sm font-medium text-stone-700">Friday reflection banner</p>
          <p class="text-stone-500 text-sm mt-0.5">Show a weekly reflection prompt every Friday</p>
        </div>
        <label class="relative inline-flex items-center cursor-pointer shrink-0">
          <%= f.check_box :show_reflection_banner,
                class: "sr-only peer",
                data: { action: "change->preferences#save" } %>
          <div class="w-11 h-6 bg-stone-200 rounded-full peer peer-checked:bg-violet-600 transition-colors after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:after:translate-x-5"></div>
        </label>
      </div>

      <%# Week start day %>
      <div class="p-5 flex items-center justify-between gap-4">
        <div>
          <p class="text-sm font-medium text-stone-700">Week starts on</p>
          <p class="text-stone-500 text-sm mt-0.5">Affects weekly stats in the Friday reflection</p>
        </div>
        <%= f.select :week_start_day,
              options_for_select(User::WEEK_START_OPTIONS, current_user.week_start_day),
              {},
              {
                class: "text-sm border border-stone-200 rounded-lg px-3 py-1.5 text-stone-700 bg-white focus:outline-none focus:ring-2 focus:ring-violet-500 focus:border-transparent shrink-0",
                data: { action: "change->preferences#save" }
              } %>
      </div>

    </div>
  <% end %>
</div>

<div class="mt-8">
  <h2 class="text-sm font-semibold text-stone-500 uppercase tracking-wide mb-3">Data</h2>
  <div class="bg-white rounded-2xl border border-stone-200/60 shadow-sm divide-y divide-stone-100">
    <div class="p-5 flex items-center justify-between">
      <div>
        <p class="text-sm font-medium text-stone-700">Export</p>
        <p class="text-stone-500 text-sm mt-0.5">Download all your data as a JSON file</p>
      </div>
      <%= link_to "Download", account_export_path, class: "text-sm text-violet-600 hover:text-violet-800 font-medium shrink-0" %>
    </div>
    <div class="p-5 flex items-center justify-between">
      <div>
        <p class="text-sm font-medium text-stone-700">Import</p>
        <p class="text-stone-500 text-sm mt-0.5">Restore data from a previous export</p>
      </div>
      <%= link_to "Upload", new_account_import_path, class: "text-sm text-violet-600 hover:text-violet-800 font-medium shrink-0" %>
    </div>
  </div>
</div>

<div class="mt-8 sm:hidden">
  <%= link_to habits_path, class: "flex items-center justify-between p-4 bg-white rounded-xl border border-stone-200/60 shadow-sm hover:shadow transition-shadow" do %>
    <div class="flex items-center gap-3">
      <div class="w-8 h-8 rounded-full bg-violet-100 flex items-center justify-center">
        <svg class="w-4 h-4 text-violet-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
        </svg>
      </div>
      <span class="font-medium text-stone-700">Habits</span>
    </div>
    <svg class="w-5 h-5 text-stone-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
    </svg>
  <% end %>
</div>

<div class="mt-8">
  <%= button_to "Sign out", session_path, method: :delete,
      class: "w-full text-center py-3 rounded-xl border border-stone-200 text-stone-600 hover:bg-stone-50 hover:text-stone-800 font-medium transition-colors cursor-pointer" %>
</div>
