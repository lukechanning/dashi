<div class="mb-8 flex items-center gap-4">
  <%= user_avatar(current_user, size: :lg) %>
  <div>
    <h1 class="text-2xl font-bold text-app-text"><%= current_user.name %></h1>
    <p class="<%= detail_value_class("mt-0") %>"><%= current_user.email %></p>
  </div>
</div>

<div class="<%= card_class("divide-y divide-app-border") %>">
  <div class="p-5 flex items-center justify-between">
    <div>
      <p class="<%= detail_label_class %>">Name</p>
      <p class="<%= detail_value_class %>"><%= current_user.name %></p>
    </div>
  </div>

  <div class="p-5 flex items-center justify-between">
    <div>
      <p class="<%= detail_label_class %>">Email</p>
      <p class="<%= detail_value_class %>"><%= current_user.email %></p>
    </div>
  </div>

  <div class="p-5 flex items-center justify-between">
    <div>
      <p class="<%= detail_label_class %>">Timezone</p>
      <p class="<%= detail_value_class %>"><%= current_user.timezone.presence || "Auto-detected" %></p>
    </div>
  </div>

  <% if current_user.admin? %>
    <div class="p-5 flex items-center justify-between">
      <div>
        <p class="<%= detail_label_class %>">Role</p>
        <p class="text-sm mt-0.5">
          <span class="bg-app-primary-soft text-app-primary rounded-full px-2 py-0.5 text-xs font-medium">Admin</span>
        </p>
      </div>
      <%= link_to "Manage Invitations", invitations_path, class: primary_link_class("text-sm font-medium") %>
    </div>
  <% end %>
</div>

<div class="mt-8" data-controller="preferences">
  <div class="flex items-center justify-between mb-3">
    <h2 class="<%= section_label_class %>">Preferences</h2>
    <span class="text-xs text-app-success opacity-0 transition-opacity duration-300" data-preferences-target="notice">✓ Saved</span>
  </div>
  <%= form_with model: current_user, url: account_path, method: :patch,
        data: { action: "turbo:submit-end->preferences#saved" } do |f| %>
    <div class="<%= card_class("divide-y divide-app-border") %>">

      <%# Appearance theme %>
      <div class="p-5 flex items-center justify-between gap-4">
        <div>
          <p class="<%= detail_label_class %>">Appearance</p>
          <p class="<%= detail_value_class %>">Choose the colour theme for your signed-in workspace</p>
        </div>
        <%= f.select :appearance_theme,
              options_for_select(
                User::APPEARANCE_THEME_OPTIONS.map { |theme| [theme.capitalize, theme] },
                current_user.appearance_theme
              ),
              {},
              {
                class: select_control_class("shrink-0"),
                data: { action: "change->preferences#themeChanged" }
              } %>
      </div>

      <%# Stale tasks banner toggle %>
      <div class="p-5 flex items-center justify-between gap-4">
        <div>
          <p class="<%= detail_label_class %>">Stale tasks banner</p>
          <p class="<%= detail_value_class %>">Remind me to review tasks that haven't been touched in a while</p>
        </div>
        <label class="relative inline-flex items-center cursor-pointer shrink-0">
          <%= f.check_box :show_stale_banner,
                class: "sr-only peer",
                data: { action: "change->preferences#staleBannerChanged" } %>
          <div class="<%= switch_track_class %>"></div>
        </label>
      </div>

      <%# Stale threshold — dims when stale banner is off %>
      <div class="p-5 flex items-center justify-between gap-4 transition-opacity"
           data-preferences-target="thresholdRow">
        <div>
          <p class="<%= detail_label_class %>">Stale after</p>
          <p class="<%= detail_value_class %>">How many days before a task is considered stale</p>
        </div>
        <%= f.select :stale_threshold_days,
              options_for_select(
                User::STALE_THRESHOLD_OPTIONS.map { |d| ["#{d} days", d] },
                current_user.stale_threshold_days
              ),
              {},
              {
                class: select_control_class("shrink-0"),
                data: { action: "change->preferences#save" }
              } %>
      </div>

      <%# Friday reflection banner toggle %>
      <div class="p-5 flex items-center justify-between gap-4">
        <div>
          <p class="<%= detail_label_class %>">Friday reflection banner</p>
          <p class="<%= detail_value_class %>">Show a weekly reflection prompt every Friday</p>
        </div>
        <label class="relative inline-flex items-center cursor-pointer shrink-0">
          <%= f.check_box :show_reflection_banner,
                class: "sr-only peer",
                data: { action: "change->preferences#save" } %>
          <div class="<%= switch_track_class %>"></div>
        </label>
      </div>

      <%# Week start day %>
      <div class="p-5 flex items-center justify-between gap-4">
        <div>
          <p class="<%= detail_label_class %>">Week starts on</p>
          <p class="<%= detail_value_class %>">Affects weekly stats in the Friday reflection</p>
        </div>
        <%= f.select :week_start_day,
              options_for_select(User::WEEK_START_OPTIONS, current_user.week_start_day),
              {},
              {
                class: select_control_class("shrink-0"),
                data: { action: "change->preferences#save" }
              } %>
      </div>

    </div>
  <% end %>
</div>

<div class="mt-8">
  <h2 class="<%= section_label_class("mb-3") %>">Data</h2>
  <div class="<%= card_class("divide-y divide-app-border") %>">
    <div class="p-5 flex items-center justify-between">
      <div>
        <p class="<%= detail_label_class %>">Export</p>
        <p class="<%= detail_value_class %>">Download your personal content and preferences as a JSON file</p>
      </div>
      <%= link_to "Download", account_export_path, class: primary_link_class("text-sm font-medium shrink-0") %>
    </div>
    <div class="p-5 flex items-center justify-between">
      <div>
        <p class="<%= detail_label_class %>">Import</p>
        <p class="<%= detail_value_class %>">Restore personal content and preferences from a previous export</p>
      </div>
      <%= link_to "Upload", new_account_import_path, class: primary_link_class("text-sm font-medium shrink-0") %>
    </div>
  </div>
</div>

<div class="mt-8 sm:hidden">
  <%= link_to habits_path, class: "flex items-center justify-between p-4 bg-app-surface rounded-xl border border-app-border shadow-sm hover:shadow transition-shadow" do %>
    <div class="flex items-center gap-3">
      <div class="w-8 h-8 rounded-full bg-app-primary-soft flex items-center justify-center">
        <svg class="w-4 h-4 text-app-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
        </svg>
      </div>
      <span class="font-medium text-app-text">Habits</span>
    </div>
    <svg class="w-5 h-5 text-app-faint" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
    </svg>
  <% end %>
</div>

<div class="mt-8">
  <%= button_to "Sign out", session_path, method: :delete,
      class: "w-full text-center py-3 rounded-xl border border-app-border #{muted_link_class} hover:bg-app-surface-muted font-medium transition-colors cursor-pointer" %>
</div>
