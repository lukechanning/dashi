<div class="mb-6">
  <%= link_to account_path, class: muted_link_class("inline-flex items-center gap-1.5 text-sm") do %>
    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
    </svg>
    Back to account
  <% end %>
</div>

<h1 class="text-2xl font-bold text-app-text mb-6">Import Data</h1>

<% if flash[:alert] %>
  <div class="mb-6 p-4 bg-app-danger-soft border border-app-danger rounded-xl text-sm text-app-danger">
    <%= flash[:alert] %>
  </div>
<% end %>

<div class="<%= card_class("p-6") %>">
  <p class="text-sm text-app-muted mb-1">Upload a previously exported Dashi JSON file to restore personal content and preferences.</p>
  <p class="text-sm text-app-muted mb-6">Import is additive — it will not delete or overwrite any existing records.</p>

  <%= form_with url: account_import_path, multipart: true do |f| %>
    <div class="mb-5">
      <%= f.label :file, "Export file (.json)", class: form_label_class %>
      <%= f.file_field :file, name: "import[file]", accept: ".json,application/json",
          class: "block w-full text-sm text-app-muted file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-medium file:bg-app-primary-soft file:text-app-primary hover:file:opacity-80 cursor-pointer" %>
    </div>

    <%= f.submit "Import", class: primary_button_class("w-full py-3 text-sm") %>
  <% end %>
</div>
