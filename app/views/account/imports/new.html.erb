<div class="mb-6">
  <%= link_to account_path, class: "inline-flex items-center gap-1.5 text-sm text-stone-500 hover:text-stone-700" do %>
    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
    </svg>
    Back to account
  <% end %>
</div>

<h1 class="text-2xl font-bold text-stone-800 mb-6">Import Data</h1>

<% if flash[:alert] %>
  <div class="mb-6 p-4 bg-red-50 border border-red-200 rounded-xl text-sm text-red-700">
    <%= flash[:alert] %>
  </div>
<% end %>

<div class="bg-white rounded-2xl border border-stone-200/60 shadow-sm p-6">
  <p class="text-sm text-stone-600 mb-1">Upload a previously exported Dashi JSON file to restore your data.</p>
  <p class="text-sm text-stone-500 mb-6">Import is additive — it will not delete or overwrite any existing records.</p>

  <%= form_with url: account_import_path, multipart: true do |f| %>
    <div class="mb-5">
      <%= f.label :file, "Export file (.json)", class: "block text-sm font-medium text-stone-700 mb-1.5" %>
      <%= f.file_field :file, name: "import[file]", accept: ".json,application/json",
          class: "block w-full text-sm text-stone-600 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-medium file:bg-violet-50 file:text-violet-700 hover:file:bg-violet-100 cursor-pointer" %>
    </div>

    <%= f.submit "Import", class: "w-full py-3 rounded-xl bg-violet-600 text-white font-medium text-sm hover:bg-violet-700 transition-colors cursor-pointer" %>
  <% end %>
</div>
