<div class="mb-8">
  <h1 class="text-3xl font-bold text-app-text">Notes</h1>
  <p class="text-app-muted mt-1">Everything you've written, in one place.</p>
</div>

<% if @notes.any? %>
  <% @notes.group_by { |n| n.created_at.to_date }.each do |date, notes| %>
    <%# Date group header %>
    <div class="mb-1 mt-6 first:mt-0">
      <p class="text-xs font-semibold text-app-faint uppercase tracking-wide">
        <% if date == Date.current %>
          Today
        <% elsif date == Date.current - 1 %>
          Yesterday
        <% else %>
          <%= date.strftime("%A, %B %-d") %>
        <% end %>
      </p>
    </div>

    <div class="space-y-3">
      <% notes.each do |note| %>
        <div class="<%= card_class("p-4") %>">
          <%# Body %>
          <p class="text-app-text text-sm whitespace-pre-wrap leading-relaxed"><%= note.body %></p>

          <%# Source + actions %>
          <div class="flex items-center justify-between mt-3 pt-3 border-t border-app-border">
            <%# Source badge %>
            <% link_info = notable_link(note) %>
            <% if link_info %>
              <%= link_to link_info[:path], class: "inline-flex items-center gap-1.5 text-xs text-app-faint hover:text-app-primary transition-colors" do %>
                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <% case link_info[:icon] %>
                  <% when :calendar %>
                    <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                  <% when :check %>
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  <% when :star %>
                    <path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
                  <% else %>
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z" />
                  <% end %>
                </svg>
                <%= link_info[:label] %>
              <% end %>
            <% end %>

            <%# Timestamp + edit/delete %>
            <div class="flex items-center gap-3">
              <span class="text-xs text-app-faint"><%= note.created_at.strftime("%-I:%M %p") %></span>
              <%= link_to "Edit", edit_polymorphic_path([note.notable, note]), class: "text-xs text-app-faint hover:text-app-muted transition-colors" %>
              <%= button_to "Delete", polymorphic_path([note.notable, note]), method: :delete,
                  data: { turbo_confirm: "Delete this note?" },
                  class: "text-xs text-app-danger hover:opacity-80 cursor-pointer transition-colors" %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
<% else %>
  <div class="text-center py-16">
    <div class="w-14 h-14 rounded-2xl bg-app-surface-muted flex items-center justify-center mx-auto mb-4">
      <svg class="w-7 h-7 text-app-faint" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
      </svg>
    </div>
    <p class="text-app-muted font-medium">No notes yet</p>
    <p class="text-app-faint text-sm mt-1">Add notes to your daily page, tasks, goals, or projects.</p>
  </div>
<% end %>
