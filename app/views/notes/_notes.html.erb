<div class="mt-6">
  <h3 class="text-sm font-semibold text-app-muted mb-3">Notes</h3>

  <% if notable.notes.any? %>
    <div class="space-y-3 mb-4">
      <% notable.notes.ordered.each do |note| %>
        <div class="bg-app-surface-muted rounded-xl p-3 text-sm border border-app-border">
          <p class="text-app-text whitespace-pre-wrap"><%= note.body %></p>
          <div class="flex items-center justify-between mt-2">
            <span class="text-xs text-app-faint"><%= note.created_at.strftime("%b %-d, %Y at %-I:%M %p") %></span>
            <div class="flex items-center gap-2">
              <%= link_to "Edit", edit_polymorphic_path([notable, note]), class: "text-xs text-app-faint hover:text-app-muted" %>
              <%= button_to "Delete", polymorphic_path([notable, note]), method: :delete,
                  data: { turbo_confirm: "Delete this note?" },
                  class: "text-xs text-app-danger hover:opacity-80 cursor-pointer" %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>

  <%= form_with model: [notable, Note.new], class: "flex items-end gap-2" do |f| %>
    <%= f.text_area :body, rows: 2, placeholder: "Add a note...",
        class: "flex-1 rounded-xl border border-app-border bg-app-surface px-3 py-2 text-sm text-app-text placeholder:text-app-faint focus:outline-none focus:ring-2 focus:ring-violet-500 focus:border-transparent" %>
    <%= f.submit "Add", class: primary_button_class("px-4 py-2 text-sm") %>
  <% end %>
</div>
