<h1 class="text-2xl font-bold text-app-text mb-6">Edit note</h1>

<%= form_with model: [@notable, @note], class: "space-y-4 max-w-lg" do |f| %>
  <div>
    <%= f.text_area :body, rows: 4, autofocus: true,
        class: form_control_class %>
  </div>

  <div class="flex items-center gap-3">
    <%= f.submit "Save", class: primary_button_class("text-sm") %>
    <%= link_to "Cancel", :back, class: muted_link_class("text-sm") %>
  </div>
<% end %>
