<div class="mb-8">
  <h1 class="text-3xl font-bold text-app-text">Upcoming</h1>
  <p class="text-app-muted mt-1">
    <%= link_to "Back to today", root_path, class: primary_link_class("font-medium") %>
  </p>
</div>

<% if @todos_by_date.any? %>
  <div class="space-y-6">
    <% @todos_by_date.each do |date, todos| %>
      <div>
        <h2 class="text-sm font-semibold text-app-muted uppercase tracking-wide mb-3">
          <%
            tomorrow = Date.current + 1
            if date == tomorrow
              day_label = "Tomorrow · #{date.strftime("%b %-d")}"
            elsif date < Date.current + 7
              day_label = "#{date.strftime("%A")} · #{date.strftime("%b %-d")}"
            else
              day_label = date.strftime("%B %-d")
            end
          %>
          <%= day_label %>
        </h2>
        <div class="space-y-2">
          <% todos.each do |todo| %>
            <div class="<%= card_class("flex items-center gap-3 rounded-xl p-3 hover:border-app-primary transition-colors") %>">
              <%= button_to toggle_todo_path(todo), method: :patch, class: "flex-shrink-0" do %>
                <div class="w-6 h-6 rounded-full border-2 flex items-center justify-center cursor-pointer transition-colors border-app-border hover:border-app-primary">
                </div>
              <% end %>
              <div class="flex-1 min-w-0">
                <span class="text-app-text"><%= todo.title %></span>
                <% if todo.project %>
                  <span class="inline-flex items-center text-xs bg-app-surface-muted text-app-muted rounded-full px-2 py-0.5 ml-2"><%= [todo.project.emoji, todo.project.title].compact.join(" ") %></span>
                <% end %>
              </div>
              <% if todo.project && todo.project.members.any? %>
                <% todo_members = ([todo.project.user] + todo.project.members.to_a).uniq %>
                <%= avatar_stack(todo_members, size: :xs, max: 3) %>
              <% end %>
              <%= link_to "Edit", edit_todo_path(todo), class: "text-xs text-app-faint hover:text-app-text transition-colors flex-shrink-0" %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <%= render "shared/empty_state", message: "No upcoming tasks scheduled." %>
<% end %>
