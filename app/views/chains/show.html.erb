<% content_for(:title) { @chain.title } %>

<div class="mb-6 flex items-center gap-3">
  <span class="text-3xl"><%= @chain.emoji.presence || "🔗" %></span>
  <div>
    <h1 class="text-3xl font-bold text-stone-800"><%= @chain.title %></h1>
    <% if @chain.complete? %>
      <span class="inline-block mt-1 text-xs font-medium text-emerald-600 bg-emerald-50 rounded-full px-2 py-0.5">Complete 🎉</span>
    <% end %>
  </div>
  <%= button_to chain_path(@chain), method: :delete,
      data: { turbo_confirm: "Delete this chain? The individual tasks will not be deleted." },
      class: "ml-auto text-xs text-stone-400 hover:text-red-600 transition-colors cursor-pointer" do %>
    Delete chain
  <% end %>
</div>

<div class="space-y-3">
  <% @chain_items.each_with_index do |item, i| %>
    <div class="flex items-center gap-4 bg-white rounded-2xl border border-stone-200/60 p-4 shadow-sm">
      <div class="w-8 h-8 rounded-full <%= item.complete? ? 'bg-violet-500' : 'bg-stone-100' %> flex items-center justify-center flex-shrink-0">
        <% if item.complete? %>
          <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
        <% else %>
          <span class="text-xs font-bold text-stone-500"><%= i + 1 %></span>
        <% end %>
      </div>
      <div class="flex-1 min-w-0">
        <p class="font-medium <%= item.complete? ? 'line-through text-stone-400' : 'text-stone-800' %>">
          <%= item.title %>
        </p>
        <% if item.target_project %>
          <p class="text-xs text-stone-400 mt-0.5"><%= item.target_project.title %></p>
        <% end %>
      </div>
      <% if item.activated? && item.todo %>
        <%= link_to edit_todo_path(item.todo),
            class: "text-xs text-violet-600 hover:text-violet-800 transition-colors" do %>
          View →
        <% end %>
      <% end %>
    </div>
  <% end %>
</div>
