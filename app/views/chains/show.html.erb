<% content_for(:title) { @chain.title } %>

<div class="mb-6 flex items-center gap-3">
  <span class="text-3xl"><%= @chain.emoji.presence || "🔗" %></span>
  <div>
    <h1 class="text-3xl font-bold text-app-text"><%= @chain.title %></h1>
    <% if @chain.complete? %>
      <span class="inline-block mt-1 text-xs font-medium text-app-success bg-app-success-soft rounded-full px-2 py-0.5">Complete 🎉</span>
    <% end %>
  </div>
  <%= button_to chain_path(@chain), method: :delete,
      data: { turbo_confirm: "Delete this chain? The individual tasks will not be deleted." },
      class: "ml-auto text-xs text-app-faint hover:text-app-danger transition-colors cursor-pointer" do %>
    Delete chain
  <% end %>
</div>

<div class="space-y-3">
  <% @chain_items.each_with_index do |item, i| %>
    <div class="<%= card_class("flex items-center gap-4 p-4") %>">
      <div class="w-8 h-8 rounded-full <%= item.complete? ? 'bg-violet-500' : 'bg-app-surface-muted' %> flex items-center justify-center flex-shrink-0">
        <% if item.complete? %>
          <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
        <% else %>
          <span class="text-xs font-bold text-app-muted"><%= i + 1 %></span>
        <% end %>
      </div>
      <div class="flex-1 min-w-0">
        <p class="font-medium <%= item.complete? ? 'line-through text-app-faint' : 'text-app-text' %>">
          <%= item.title %>
        </p>
        <% if item.target_project %>
          <p class="text-xs text-app-faint mt-0.5"><%= item.target_project.title %></p>
        <% end %>
      </div>
      <% if item.activated? && item.todo %>
        <%= link_to edit_todo_path(item.todo),
            class: primary_link_class("text-xs transition-opacity") do %>
          View →
        <% end %>
      <% end %>
    </div>
  <% end %>
</div>
