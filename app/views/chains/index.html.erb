<% content_for(:title) { "Chains" } %>

<div class="mb-6">
  <h1 class="text-3xl font-bold text-stone-800">Chains</h1>
  <p class="text-stone-500 mt-1">Your sequential task chains.</p>
</div>

<% if @chains.any? %>
  <div class="space-y-3">
    <% @chains.each do |chain| %>
      <%= link_to chain_path(chain), class: "block bg-white rounded-2xl border border-stone-200/60 p-4 shadow-sm hover:shadow transition-shadow" do %>
        <div class="flex items-center gap-3">
          <span class="text-2xl"><%= chain.emoji.presence || "🔗" %></span>
          <div class="flex-1 min-w-0">
            <p class="font-semibold text-stone-800"><%= chain.title %></p>
            <p class="text-xs text-stone-400 mt-0.5"><%= pluralize(chain.chain_items.size, "step") %></p>
          </div>
          <% if chain.complete? %>
            <span class="text-xs font-medium text-emerald-600 bg-emerald-50 rounded-full px-2 py-0.5">Complete</span>
          <% end %>
        </div>
      <% end %>
    <% end %>
  </div>
<% else %>
  <%= render "shared/empty_state", message: "No chains yet. Create one with the + button." %>
<% end %>
