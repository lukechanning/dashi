<%# Weekly reflection overlay — hidden until banner "Reflect" button is clicked %>
<div
  id="reflection-overlay"
  data-reflection-target="overlay"
  class="fixed inset-0 z-50 bg-app-bg/70 backdrop-blur-sm flex items-center justify-center p-4 hidden"
>
  <div class="bg-app-surface rounded-3xl shadow-2xl w-full max-w-lg max-h-[90vh] flex flex-col overflow-hidden border border-app-border">
    <%# Header %>
    <div class="px-6 pt-6 pb-4 border-b border-app-border flex-shrink-0">
      <div class="flex items-center justify-between">
        <h2 class="text-lg font-bold text-app-text">Week in review</h2>
        <button
          data-action="reflection#close"
          class="text-app-faint hover:text-app-muted transition-colors cursor-pointer"
          aria-label="Close"
        >
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
      <p class="text-xs text-app-faint mt-1"><%= @date.beginning_of_week.strftime("%b %-d") %> – <%= @date.strftime("%b %-d") %></p>
    </div>

    <div class="overflow-y-auto flex-1">
      <%# Week stats %>
      <div class="px-6 py-5 border-b border-app-border">
        <div class="grid grid-cols-2 gap-3">
          <div class="bg-app-success-soft rounded-2xl p-4 text-center">
            <p class="text-3xl font-bold text-app-success"><%= @week_stats[:completed] %></p>
            <p class="text-xs text-app-success mt-1 font-medium">completed</p>
          </div>
          <div class="bg-app-surface-muted rounded-2xl p-4 text-center">
            <p class="text-3xl font-bold text-app-muted"><%= @week_stats[:incomplete] %></p>
            <p class="text-xs text-app-muted mt-1 font-medium">unfinished</p>
          </div>
        </div>
      </div>

      <%# Unfinished tasks %>
      <% if @week_incomplete_todos.any? %>
        <div class="px-6 py-4 border-b border-app-border">
          <p class="text-xs font-semibold text-app-muted uppercase tracking-wide mb-3">What to do with unfinished tasks?</p>
          <div class="space-y-2">
            <% @week_incomplete_todos.each do |todo| %>
              <div class="flex items-center gap-3 p-3 rounded-xl bg-app-surface-muted" data-todo-id="<%= todo.id %>">
                <span class="flex-1 text-sm text-app-text min-w-0"><%= todo.title %></span>
                <div class="flex items-center gap-2 flex-shrink-0">
                  <button
                    data-action="reflection#carryForward"
                    data-todo-id="<%= todo.id %>"
                    class="text-xs px-3 py-1.5 rounded-lg bg-app-surface border border-app-border text-app-muted hover:border-app-primary hover:text-app-primary hover:bg-app-primary-soft transition-colors cursor-pointer"
                  >
                    Keep it
                  </button>
                  <button
                    data-action="reflection#letItGo"
                    data-todo-id="<%= todo.id %>"
                    class="text-xs px-3 py-1.5 rounded-lg bg-app-surface border border-app-border text-app-faint hover:border-app-danger hover:text-app-danger hover:bg-app-danger-soft transition-colors cursor-pointer"
                  >
                    Let it go
                  </button>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      <% else %>
        <div class="px-6 py-6 text-center border-b border-app-border">
          <p class="text-sm text-app-faint">Everything finished — excellent week!</p>
        </div>
      <% end %>

      <%# Week note %>
      <div class="px-6 py-5">
        <p class="text-xs font-semibold text-app-muted uppercase tracking-wide mb-2">Week note (optional)</p>
        <%= form_with url: daily_page_notes_path(@daily_page),
            data: { reflection_target: "noteForm", action: "submit->reflection#saveNote" } do |f| %>
          <%= f.text_area :body,
              placeholder: "What did you learn this week? What would you do differently?",
              rows: 3,
              data: { reflection_target: "noteBody" },
              class: "w-full text-sm border border-app-border bg-app-surface text-app-text rounded-xl px-3 py-2.5 focus:outline-none focus:ring-2 focus:ring-violet-400 resize-none placeholder:text-app-faint" %>
        <% end %>
      </div>
    </div>

    <%# Footer %>
    <div class="px-6 py-4 border-t border-app-border flex-shrink-0">
      <button
        data-action="reflection#finish"
        class="w-full py-3 text-sm font-semibold rounded-2xl bg-violet-600 text-white hover:bg-violet-700 transition-colors cursor-pointer"
      >
        Done reflecting
      </button>
    </div>
  </div>
</div>
