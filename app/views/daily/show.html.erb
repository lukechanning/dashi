<%# Week strip + collapsible calendar %>
<div data-controller="calendar-panel">
  <div class="flex items-center gap-3 mb-2">
    <div class="flex-1">
      <%= render "shared/week_strip", selected_date: @date, today: Date.current %>
    </div>
    <button data-action="calendar-panel#toggle" class="flex flex-col items-center justify-center w-10 h-10 rounded-xl text-app-faint hover:text-app-muted hover:bg-app-surface-muted transition-colors cursor-pointer" title="Calendar view">
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
      </svg>
      <svg data-calendar-panel-target="icon" class="w-3 h-3 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
      </svg>
    </button>
  </div>

  <%# Collapsible calendar panel %>
  <div data-calendar-panel-target="panel"
       class="grid transition-[grid-template-rows] duration-300 ease-in-out mb-4"
       style="grid-template-rows: 0fr">
    <div class="overflow-hidden">
      <div class="pt-2 pb-1">
        <%= turbo_frame_tag "calendar", src: calendar_path(month: @date.strftime("%Y-%m")) do %>
          <div class="h-20 flex items-center justify-center text-app-faint text-sm">Loading...</div>
        <% end %>
      </div>
    </div>
  </div>
</div>

<div class="mb-8">
  <% if @viewing_history %>
    <h1 class="text-3xl font-bold text-app-text"><%= @date.strftime("%A, %B %-d") %></h1>
    <p class="text-app-muted mt-1">
      <%= link_to "Back to today", root_path, class: "text-app-primary hover:opacity-85 font-medium" %>
    </p>
  <% else %>
    <h1 class="text-3xl font-bold text-app-text">Hello <%= current_user.name %>,</h1>
    <p class="text-app-muted mt-1">
      <%= Date.current.strftime("%A, %B %-d") %> &mdash;
      <% today_count = @todos.count { |t| !t.complete? } %>
      <% if today_count > 0 %>
        You have <span class="font-medium text-app-text"><%= pluralize(today_count, "task") %></span> today
      <% else %>
        No tasks today
      <% end %>
    </p>
  <% end %>
</div>

<% if @stale_todos.any? %>
  <div data-controller="stale-wizard" data-stale-wizard-current-index-value="0">
    <%= render "daily/stale_banner" %>
    <%= render "daily/stale_wizard" %>
  </div>
<% end %>

<% if @show_reflection %>
  <div data-controller="reflection">
    <%= render "daily/reflection_banner" %>
    <%= render "daily/reflection_overlay" %>
  </div>
<% end %>

<% unless @viewing_history %>
  <%# Stat cards %>
  <div class="grid grid-cols-3 gap-4 mb-8">
    <div class="bg-stat-lavender rounded-2xl p-4">
      <div class="flex items-center gap-2 mb-2">
        <svg class="w-5 h-5 text-stat-lavender-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <span class="text-sm font-medium text-stat-lavender-accent">Today</span>
      </div>
      <span class="text-3xl font-bold text-stat-lavender-accent"><%= today_count %></span>
    </div>

    <%= link_to upcoming_path, class: "bg-stat-yellow rounded-2xl p-4 block hover:opacity-90 transition-opacity" do %>
      <div class="flex items-center gap-2 mb-2">
        <svg class="w-5 h-5 text-stat-yellow-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
        <span class="text-sm font-medium text-stat-yellow-accent">Upcoming</span>
      </div>
      <span class="text-3xl font-bold text-stat-yellow-accent"><%= @upcoming_count %></span>
    <% end %>

    <div class="bg-stat-mint rounded-2xl p-4">
      <div class="flex items-center gap-2 mb-2">
        <svg class="w-5 h-5 text-stat-mint-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
        </svg>
        <span class="text-sm font-medium text-stat-mint-accent">Done</span>
      </div>
      <span class="text-3xl font-bold text-stat-mint-accent"><%= @done_count %></span>
    </div>
  </div>

<% end %>

<%# Tasks heading — focus-mode controller wraps the heading + fixed overlays only %>
<% if @viewing_history %>
  <div class="flex items-center justify-between mb-3">
    <h2 class="text-sm font-semibold text-app-muted uppercase tracking-wide">Tasks That Day</h2>
  </div>
<% else %>
  <div data-controller="focus-mode">
    <%= render "daily/focus_panel" %>
    <%= render "daily/focus_view" %>
    <div class="flex items-center justify-between mb-3">
      <h2 class="text-sm font-semibold text-app-muted uppercase tracking-wide">Tasks</h2>
      <div class="flex items-center gap-3">
        <button
          id="focus-mode-btn"
          data-action="focus-mode#openPanel"
          class="inline-flex items-center gap-1 text-sm font-medium text-app-faint hover:text-app-primary transition-colors cursor-pointer"
          title="Enter focus mode"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
          </svg>
          Focus
        </button>
        <button
          data-action="creation-wizard#open"
          class="inline-flex items-center gap-1 text-sm font-medium text-app-primary hover:opacity-85 transition-colors cursor-pointer"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
          </svg>
          Add
        </button>
      </div>
    </div>
  </div>
<% end %>

<%# Task list %>
<% if @todos.any? %>
  <div class="space-y-2">
    <% @todos.each do |todo| %>
      <% ci = !@viewing_history ? todo.chain_item : nil %>
      <% next_ci = ci ? ci.chain.next_item_after(ci) : nil %>
      <%# Future steps: chain items after the current position, used for peek-ahead %>
      <% future_steps = ci && !todo.complete? ? ci.chain.chain_items.select { |item| item.position > ci.position } : [] %>

      <%# Stack wrapper — adds ghost cards behind chain todos that have upcoming steps %>
      <div class="<%= future_steps.any? ? 'relative pb-3' : '' %>">
        <% if future_steps.size >= 2 %>
          <div class="absolute bottom-0 left-4 right-4 h-4 bg-app-success-soft rounded-xl border border-app-success/40"></div>
        <% end %>
        <% if future_steps.any? %>
          <div class="absolute bottom-0 left-2 right-2 h-4 bg-app-success-soft rounded-xl border border-app-success/60"></div>
        <% end %>

        <%# Main todo card — green left accent for chain items %>
        <%= tag.div(
          class: "relative bg-app-surface rounded-xl border border-app-border #{ci ? 'border-l-[3px] border-l-app-success' : ''} shadow-sm#{' hover:shadow transition-shadow' unless @viewing_history}",
          data: @viewing_history ? {} : { controller: "todo-row", todo_row_toggle_url_value: toggle_todo_path(todo) }
        ) do %>
          <div class="flex items-center gap-3 p-3 flex-wrap">
            <% if @viewing_history %>
              <div class="w-6 h-6 rounded-full border-2 flex items-center justify-center shrink-0
                <%= todo.complete? ? 'bg-violet-500 border-violet-500' : 'border-app-border' %>">
                <% if todo.complete? %>
                  <svg class="w-3.5 h-3.5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                <% end %>
              </div>
            <% else %>
              <%# Fetch-driven toggle button for chain-aware completion %>
              <button
                data-action="todo-row#toggle"
                data-todo-row-target="check"
                class="shrink-0 w-6 h-6 rounded-full border-2 flex items-center justify-center cursor-pointer transition-colors
                  <%= todo.complete? ? 'bg-violet-500 border-violet-500' : 'border-app-border hover:border-violet-400' %>"
                aria-label="<%= todo.complete? ? 'Mark incomplete' : 'Mark complete' %>"
              >
                <svg
                  data-todo-row-target="checkIcon"
                  class="w-3.5 h-3.5 text-white <%= todo.complete? ? '' : 'hidden' %>"
                  fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
              </button>
            <% end %>

            <div class="flex-1 min-w-0">
              <span data-todo-row-target="title" class="<%= todo.complete? ? 'line-through text-app-faint' : 'text-app-text' %>">
                <%= todo.title %>
              </span>
              <%# Habit indicator %>
              <% if todo.from_habit? %>
                <svg class="w-3.5 h-3.5 text-app-faint inline ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" title="Recurring habit">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                </svg>
              <% end %>
              <%# Project badge %>
              <% if todo.project %>
                <span class="inline-flex items-center text-xs bg-app-surface-muted text-app-muted rounded-full px-2 py-0.5 ml-2"><%= [todo.project.emoji, todo.project.title].compact.join(" ") %></span>
              <% end %>
            </div>

            <% if todo.project && todo.project.members.any? %>
              <% todo_members = ([todo.project.user] + todo.project.members.to_a).uniq %>
              <%= avatar_stack(todo_members, size: :xs, max: 3) %>
            <% end %>
            <% if @viewing_history && todo.complete? && todo.due_date && todo.due_date != @date %>
              <span class="text-xs text-app-faint shrink-0">due <%= todo.due_date.strftime("%b %-d") %></span>
            <% elsif !@viewing_history && todo.due_date %>
              <span class="text-xs text-app-faint shrink-0"><%= todo.due_date.strftime("%b %-d") %></span>
            <% end %>
            <% unless @viewing_history %>
              <%= link_to "Edit", edit_todo_path(todo), class: "text-xs text-app-faint hover:text-app-muted transition-colors flex-shrink-0" %>
            <% end %>

            <%# Chain prompt — shown after completing a chained todo %>
            <% if ci && next_ci && !next_ci.activated? %>
              <div data-todo-row-target="chainPrompt" class="hidden w-full pt-3 mt-1 border-t border-app-border">
                <p class="text-xs text-app-muted mb-2">
                  Next in chain:
                  <span class="font-semibold text-app-text"><%= next_ci.title %></span>
                </p>
                <div class="flex items-center gap-2 flex-wrap">
                  <button
                    data-action="todo-row#activateNow"
                    data-todo-row-chain-id-param="<%= ci.chain_id %>"
                    data-todo-row-chain-item-id-param="<%= next_ci.id %>"
                    class="text-xs font-semibold text-white bg-violet-600 rounded-lg px-3 py-1.5 hover:bg-violet-700 transition-colors cursor-pointer"
                  >
                    Start today
                  </button>
                  <input
                    type="date"
                    data-chain-date-input
                    value="<%= Date.tomorrow %>"
                    min="<%= Date.current %>"
                    class="text-xs border border-app-border bg-app-surface rounded-lg px-2 py-1.5 focus:ring-2 focus:ring-violet-400 focus:outline-none"
                    autocomplete="off"
                  >
                  <button
                    data-action="todo-row#activateWithDate"
                    data-todo-row-chain-id-param="<%= ci.chain_id %>"
                    data-todo-row-chain-item-id-param="<%= next_ci.id %>"
                    class="text-xs font-medium text-app-muted hover:text-app-primary transition-colors cursor-pointer"
                  >
                    Schedule for date
                  </button>
                </div>
              </div>
            <% end %>
          </div>

          <%# Chain peek footer — collapsible panel showing upcoming steps %>
          <% if ci && future_steps.any? %>
            <div data-controller="chain-peek" class="border-t border-app-border">
              <button
                data-action="chain-peek#toggle"
                class="w-full flex items-center justify-between px-3 py-2 text-left hover:bg-app-surface-muted rounded-b-xl transition-colors cursor-pointer"
              >
                <span class="flex items-center gap-1.5 min-w-0">
                  <svg class="w-3 h-3 text-app-success shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
                  </svg>
                  <span class="text-xs font-medium text-app-success truncate"><%= ci.chain.title %></span>
                  <span class="text-xs text-app-faint shrink-0">· Step <%= ci.position + 1 %> of <%= ci.chain.chain_items.size %></span>
                </span>
                <svg data-chain-peek-target="chevron" class="w-3.5 h-3.5 text-app-faint transition-transform duration-150 shrink-0 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </button>

              <div data-chain-peek-target="panel" class="hidden px-3 pb-3 space-y-2">
                <% future_steps.each_with_index do |step, i| %>
                  <div class="flex items-center gap-2">
                    <span class="w-4 h-4 rounded-full bg-app-success-soft text-app-success text-[10px] font-bold flex items-center justify-center shrink-0"><%= ci.position + i + 2 %></span>
                    <span class="text-xs text-app-muted truncate"><%= step.title %></span>
                    <% if step.target_project %>
                      <span class="text-xs text-app-faint shrink-0 ml-auto">· <%= step.target_project.title %></span>
                    <% end %>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
    <% end %>
  </div>
<% else %>
  <%= render "shared/empty_state", message: @viewing_history ? "No tasks were recorded for this day." : "Nothing on the list for today. Enjoy your day!" %>
<% end %>

<%= render "notes/notes", notable: @daily_page %>

<% unless @viewing_history %>
  <%# Activity graph %>
  <div class="mt-8">
    <h2 class="text-sm font-semibold text-app-muted uppercase tracking-wide mb-3">Activity</h2>
    <div class="bg-app-surface rounded-2xl p-5 shadow-sm border border-app-border">
      <%= render "shared/contribution_graph", record: current_user %>
    </div>
  </div>
<% end %>
