<div id="stale-banner" data-stale-wizard-target="banner" class="mb-6 rounded-2xl bg-app-warning-soft border border-app-warning p-4 flex items-center justify-between gap-4">
  <div class="flex items-center gap-3">
    <div class="flex-shrink-0 w-9 h-9 rounded-xl bg-app-surface-muted flex items-center justify-center">
      <svg class="w-5 h-5 text-app-warning" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
    </div>
    <div>
      <p class="text-sm font-semibold text-app-text">
        <%= pluralize(@stale_todos.size, "task") %> <%= @stale_todos.size == 1 ? "has" : "have" %> been waiting a while
      </p>
      <p class="text-xs text-app-warning mt-0.5">Take a moment to decide what to do with <%= @stale_todos.size == 1 ? "it" : "them" %>.</p>
    </div>
  </div>
  <div class="flex items-center gap-2 flex-shrink-0">
    <button
      data-action="stale-wizard#open"
      class="px-4 py-2 text-sm font-medium rounded-xl bg-app-warning text-app-bg hover:opacity-90 transition-colors cursor-pointer"
    >
      Review
    </button>
    <button
      data-action="stale-wizard#dismissBanner"
      class="w-8 h-8 flex items-center justify-center rounded-lg text-app-warning hover:bg-app-surface-muted transition-colors cursor-pointer"
      aria-label="Dismiss"
    >
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>
</div>
